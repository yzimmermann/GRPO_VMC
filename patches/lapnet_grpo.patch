+def _global_mask_sum(mask: jnp.ndarray) -> jnp.ndarray:
+  return constants.psum(jnp.sum(mask))
+
+
+def _masked_global_mean(value: jnp.ndarray, mask: jnp.ndarray) -> jnp.ndarray:
+  denom = jnp.maximum(_global_mask_sum(mask), 1.0)
+  numer = constants.psum(jnp.sum(value * mask))
+  return numer / denom
+
+
+def _masked_global_fraction(value: jnp.ndarray, mask: jnp.ndarray) -> jnp.ndarray:
+  denom = jnp.maximum(_global_mask_sum(mask), 1.0)
+  numer = constants.psum(jnp.sum(value * mask))
+  return numer / denom
+
+
+def make_grpo_training_step(
+    mcmc_step,
+    total_energy: qmc_loss_functions.TotalEnergy,
+    batch_network: networks.LogWaveFuncLike,
+    optimizer: optax.GradientTransformation,
+    inner_steps: int,
+    clip_epsilon: float,
+    advantage_epsilon: float,
+    max_advantage: float,
+) -> Step:
+  """Factory to create a GRPO step: one MCMC sample pass plus K inner updates."""
+
+  @functools.partial(constants.pmap, donate_argnums=(1, 2, 3, 4))
+  def step(data: jnp.ndarray,
+           params: networks.ParamTree, state: Optional[optax.OptState],
+           key: chex.PRNGKey, mcmc_width: jnp.ndarray) -> StepResults:
+    mcmc_key, loss_key = jax.random.split(key, num=2)
+    data, pmove = mcmc_step(params, data, mcmc_key, mcmc_width)
+
+    loss, aux_data = total_energy(params, loss_key, data)
+    mask = jax.lax.stop_gradient(aux_data.outlier_mask.astype(aux_data.local_energy.dtype))
+    masked_count = jnp.maximum(_global_mask_sum(mask), 1.0)
+
+    local_energy = jax.lax.stop_gradient(aux_data.local_energy)
+    centered_energy = (local_energy - jax.lax.stop_gradient(loss)) * mask
+    variance = constants.psum(jnp.sum(centered_energy**2)) / masked_count
+    advantage_std = jnp.sqrt(jnp.maximum(variance, 0.0))
+    std_denom = jnp.maximum(advantage_std, advantage_epsilon)
+    advantages = -centered_energy / std_denom
+    if max_advantage > 0.0:
+      advantages = jnp.clip(advantages, -max_advantage, max_advantage)
+    advantages = jax.lax.stop_gradient(advantages)
+    old_log_psi = jax.lax.stop_gradient(batch_network(params, data))
+
+    def grpo_loss(curr_params: networks.ParamTree):
+      log_psi = batch_network(curr_params, data)
+      log_ratio = jnp.clip(2.0 * (log_psi - old_log_psi), a_min=-30.0, a_max=30.0)
+      ratio = jnp.exp(log_ratio)
+      clipped_ratio = jnp.clip(ratio, 1.0 - clip_epsilon, 1.0 + clip_epsilon)
+      surrogate_unclipped = ratio * advantages
+      surrogate_clipped = jax.lax.stop_gradient(clipped_ratio) * advantages
+      objective = _masked_global_mean(
+          jnp.minimum(surrogate_unclipped, surrogate_clipped), mask)
+      clip_fraction = _masked_global_fraction(
+          (ratio != clipped_ratio).astype(mask.dtype), mask)
+      approx_kl = _masked_global_mean(ratio - 1.0 - log_ratio, mask)
+      return -objective, (objective, clip_fraction, approx_kl)
+
+    def inner_update(carry, _):
+      curr_params, curr_state = carry
+      (loss_value, (objective, clip_fraction, approx_kl)), grad = jax.value_and_grad(
+          grpo_loss, has_aux=True)(curr_params)
+      del loss_value
+      grad = constants.pmean(grad)
+      updates, curr_state = optimizer.update(grad, curr_state, curr_params)
+      curr_params = optax.apply_updates(curr_params, updates)
+      return (curr_params, curr_state), (objective, clip_fraction, approx_kl)
+
+    (new_params, new_state), (objectives, clip_fractions, approx_kls) = jax.lax.scan(
+        inner_update,
+        (params, state),
+        xs=None,
+        length=inner_steps)
+
+    grpo_stats = GRPOStats(
+        objective=objectives[-1],
+        clip_fractions=clip_fractions,
+        approx_kls=approx_kls,
+        advantage_std=advantage_std)
+    return data, new_params, new_state, loss, aux_data, pmove, grpo_stats
 
   return step
 
